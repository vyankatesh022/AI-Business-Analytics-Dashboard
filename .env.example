# Global Environment Variables Example
# Copy this file to .env and configure it for local docker-compose

# Base URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Environment
ENV=local
NODE_ENV=development

# Postgres (Local Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_ai
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/enterprise_ai

# Redis (Local Docker)
REDIS_URL=redis://redis:6379/0
