# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE - AI BUSINESS ANALYTICS PLATFORM
# ==============================================================================
# Instructions:
# 1. Copy this file to a new file named '.env'.
# 2. Populate the actual credentials without sharing or committing the '.env' file.
# 3. Do NOT hardcode production secrets in this template.
# ==============================================================================

# Global Configurations
PORT=8000
ENVIRONMENT=development # development, staging, production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend Authentication Security
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here_min_32_characters_long

# Database - Supabase (PostgreSQL)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project_ref].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[project_ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AI & Machine Learning Services
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Payment Integration (Stripe & Razorpay)
# Razorpay (India Subscriptions)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Stripe (Global Subscriptions)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Workflow Automation (n8n)
N8N_API_KEY=your_n8n_api_key_here
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-workflow-id

# Observability & Monitoring
SENTRY_DSN=https://your_sentry_dsn_here@o0.ingest.sentry.io/0
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_public_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
